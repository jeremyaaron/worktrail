# API runtime
NODE_ENV=development
API_PORT=3000
DATABASE_URL=postgres://worktrail:worktrail@localhost:5432/worktrail

# Development CORS for Angular dev server. Set to false for same-origin production preview.
CORS_ORIGIN=http://localhost:4200

# Production preview static asset serving. Defaults to false in development and true in production.
WORKTRAIL_SERVE_STATIC=false
# WORKTRAIL_STATIC_ASSETS_PATH=apps/web/dist/worktrail-web/browser

# Destructive database reset safety. Keep unset for normal local use.
# WORKTRAIL_ALLOW_DATABASE_RESET=true

# E2E controls. Keep unset unless intentionally inspecting a prepared or mutated database.
# WORKTRAIL_E2E_SKIP_DB_RESET=true
# WORKTRAIL_E2E_SKIP_DB_RESTORE=true
